**/.DS_Store

# Secrets — never commit. .example files are tracked.
.streamlit/secrets.toml
.env

# Python build artifacts
__pycache__/
*.pyc
.pytest_cache/

# Virtual environments
.venv/
venv/

# Runtime state (SQLite is regenerated by db_service on first run)
db/*.db
db/*.db-journal
db/*.db-wal
db/*.db-shm

# SQLite anywhere (e.g. test temp dbs) — never commit databases
*.db
*.db-journal
*.db-wal
*.db-shm
