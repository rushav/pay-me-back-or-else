# Local development reference — copy to .env if your editor / tooling
# needs the env var, but THIS APP DOES NOT READ FROM .env DIRECTLY.
#
# Streamlit (both local and on Streamlit Community Cloud) reads secrets
# from .streamlit/secrets.toml via st.secrets[...]. To run the app
# locally, copy .streamlit/secrets.toml.example to .streamlit/secrets.toml
# and put your real key there.
#
# Production: Streamlit Community Cloud hosts secrets in its own UI —
# you paste the TOML there at deploy time, not via this file.

ANTHROPIC_API_KEY=sk-ant-...
